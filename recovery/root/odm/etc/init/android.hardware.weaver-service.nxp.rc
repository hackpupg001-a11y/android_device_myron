service odm.weaver_nxp /odm/bin/hw/android.hardware.weaver-service.nxp-qti
    class hal
    user root
    group root system
    interface aidl android.hardware.weaver.IWeaver/default
    setenv LD_LIBRARY_PATH /vendor/lib64:/vendor/lib64/hw:/system/lib64:/sbin:/odm/lib64
    disabled
    seclabel u:r:recovery:s0
